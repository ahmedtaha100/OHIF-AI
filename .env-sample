# =============================================================================
# OHIF-AI — environment template for Docker Compose
# =============================================================================
# Copy this file to `.env` in the same directory as `docker-compose.yml`:
#   cp .env-sample .env
#
# Docker Compose loads `.env` automatically and injects the variables below into
# the `monai_sam2` service (see `docker-compose.yml` → `monai_sam2.environment`).
# The MONAI infer task (`monai-label/.../basic_infer.py`) reads them with
# `os.environ.get(...)`.
#
# Security: never commit a real `.env` file. Keep secrets in `.env` only on
# machines that need them, with restrictive file permissions (e.g. chmod 600).
# =============================================================================

# -----------------------------------------------------------------------------
# Hugging Face
# -----------------------------------------------------------------------------
# Used for: authenticated Hub downloads (e.g. MedGemma weights), and the
# Hugging Face router API for Kimi / Qwen VLM calls in `basic_infer.py`.
#
# Create a token: https://huggingface.co/settings/tokens
HF_TOKEN=

# -----------------------------------------------------------------------------
# VLM providers (Gemini, OpenAI, Anthropic)
# -----------------------------------------------------------------------------
# Used when the OHIF toolbox selects the corresponding provider; the backend
# resolves keys from the request body first, then these environment variables.

# Google Gemini — https://aistudio.google.com/apikey
GEMINI_API_KEY=

# OpenAI — https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Anthropic (Claude) — https://console.anthropic.com/
ANTHROPIC_API_KEY=
